KSTOCK_MODE=analysis
KSTOCK_BROKER=KIS
KSTOCK_KIS_APP_KEY=
KSTOCK_KIS_APP_SECRET=
KSTOCK_KIS_ACCOUNT_NO=
KSTOCK_KIS_ACCOUNT_PRODUCT_CODE=01
KSTOCK_KIS_IS_MOCK=true
KSTOCK_TELEGRAM_BOT_TOKEN=
# Telegram numeric user ID only. Do not put @username here.
KSTOCK_TELEGRAM_OWNER_ID=
# Strong random secret. Do not use "change-me" in real tests.
KSTOCK_WEBHOOK_SECRET=change-me
# Fast-ACK mode (default true) to process orders asynchronously and acknowledge TradingView within 3s.
KSTOCK_WEBHOOK_FAST_ACK=true
# Conservative background processing concurrency for webhook signals.
KSTOCK_WEBHOOK_BACKGROUND_MAX_CONCURRENCY=1
KSTOCK_HOST=0.0.0.0
KSTOCK_PORT=8090
KSTOCK_TIMEZONE=Asia/Seoul
KSTOCK_CONFIRM_LIVE_TRADING=no
KSTOCK_MAX_SCAN_SYMBOLS=20

